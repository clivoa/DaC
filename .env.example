# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit real credentials.

# ── GitHub ────────────────────────────────────────────────────────────────────

# Your GitHub username or organization name
GITHUB_OWNER=your-github-username

# The name of this repository
GITHUB_REPO=DaC

# Authentication — choose one:
#
# Option A: One-time registration token (from GitHub UI, expires ~1 hour)
#   Go to: Settings → Actions → Runners → New self-hosted runner
#   Only needed on first container start; config is persisted in a Docker volume.
RUNNER_TOKEN=

# Option B: Personal Access Token with 'repo' scope (persistent, recommended)
#   Create at: https://github.com/settings/tokens
#   Enables auto-registration on each container start and graceful deregistration on stop.
GITHUB_PAT=

# ── Runner ────────────────────────────────────────────────────────────────────

# Display name for the runner in GitHub (Settings → Actions → Runners)
RUNNER_NAME=dac-runner

# Labels assigned to the runner — must match runs-on in the workflow files
RUNNER_LABELS=self-hosted,linux,dac

# ── Splunk ────────────────────────────────────────────────────────────────────

# REST API endpoint — the runner reaches Splunk by container name on the shared Docker network.
# Run: docker network connect dac_default splunk
SPLUNK_URL=https://splunk:8089

# Bearer token — preferred authentication method.
# Generate in Splunk: Settings → Tokens → New Token
SPLUNK_TOKEN=

# Username/password — fallback if token is not set
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=

# Target Splunk app where saved searches will be created
SPLUNK_APP=search
