# Copy this file to .env and fill in the values
# .env is git-ignored — never commit credentials

# GitHub repository (owner = your username or org)
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

# Personal Access Token with 'repo' scope
# Create at: https://github.com/settings/tokens
GITHUB_PAT=<pat-with-repo-scope>

# Runner display name (optional, defaults to dac-runner-<hostname>)
RUNNER_NAME=dac-runner

# Runner labels — must include 'self-hosted' and match 'runs-on' in workflows
RUNNER_LABELS=self-hosted,linux,dac

# Splunk REST API endpoint (management port 8089)
# From the runner container, use host.internal to reach the Orbstack host
SPLUNK_URL=https://host.internal:8089

# Authentication — use token (preferred) or username/password
SPLUNK_TOKEN=
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=

# Target Splunk app for detections
SPLUNK_APP=search
